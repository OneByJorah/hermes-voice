# Copy this to .env and fill in for your setup.
# Only the variables for your chosen LLM_BACKEND need to be set.

# ---- LLM backend selection: ollama | llamacpp | api ----
LLM_BACKEND=ollama

# -- ollama --
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# -- llamacpp (run `llama-server -m model.gguf --port 8080` separately) --
LLAMACPP_HOST=http://127.0.0.1:8080

# -- api (hosted) --
API_PROVIDER=anthropic        # anthropic | openai
API_BASE_URL=https://api.anthropic.com/v1/messages
API_MODEL=claude-sonnet-4-6
API_KEY=

# ---- Speech ----
WHISPER_MODEL=small.en        # base.en / small.en / medium.en
WHISPER_DEVICE=cuda           # cuda or cpu
PIPER_VOICE=/piper-voices/en_US-amy-medium.onnx

# ---- Bot WS server ----
BOT_WS_PORT=8765
